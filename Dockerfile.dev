FROM node:20-slim

# Install bun for package management (bun.lock)
RUN npm install -g bun@1.2.15

WORKDIR /app

# Install dependencies first (layer caching)
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# Copy source
COPY . .

EXPOSE 8000 9929

CMD ["npx", "gatsby", "develop", "-H", "0.0.0.0"]
